# LINE Messaging API credentials
# Get these from https://developers.line.biz/console/
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# Shared secret for protecting trigger/admin endpoints
# Use a strong random string, e.g.: openssl rand -hex 32
TRIGGER_SECRET=your_shared_secret_here

# Message sent when /arrived-home is triggered
HOME_MESSAGE=I just got home! 🏠

# Server port (default: 3000)
PORT=3000
